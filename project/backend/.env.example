# ============================================================================
# Agent 工作台系统 — 后端环境变量模板
# ============================================================================
# 使用方法：
#   1. 复制本文件为 .env:   cp .env.example .env
#   2. 编辑 .env，填入你的实际值
#   3. 启动后端时 Pydantic Settings 会自动加载
#
# 注意：.env 文件已加入 .gitignore，不会被提交到 Git
# ============================================================================

# ----------------------------------------------------------------------------
# Database — 必填
# ----------------------------------------------------------------------------
# PostgreSQL 连接串（不需要写 asyncpg 驱动，程序会自动处理）
# 格式: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://agent_user:agent_password@localhost:5432/agent_db

# ----------------------------------------------------------------------------
# Model API Keys — 至少填一个
# ----------------------------------------------------------------------------
# DeepSeek API Key — https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# Kimi (Moonshot) API Key — https://platform.moonshot.cn/
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1

# OpenAI API Key（可选，预留）
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Workspace — 可选
# ----------------------------------------------------------------------------
# 工作区根目录（会话级文件存储位置）
# 默认使用项目目录下的 workspaces/ 文件夹
WORKSPACE_ROOT=./workspaces

# 本地缓存目录
WORKSPACE_LOCAL_CACHE=./workspace_cache

# ----------------------------------------------------------------------------
# Optional: Redis — 可选
# ----------------------------------------------------------------------------
# Redis 连接串（当前版本未强制使用）
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# Optional: Sentry — 可选
# ----------------------------------------------------------------------------
# Sentry DSN 用于错误追踪
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Logging — 可选
# ----------------------------------------------------------------------------
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Security — 可选（生产环境务必修改）
# ----------------------------------------------------------------------------
# JWT 签名密钥 — 生产环境请使用强随机字符串
SECRET_KEY=dev-secret-key-change-in-production

# Access Token 过期时间（分钟），默认 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------------------------------------------------------
# Server — 可选
# ----------------------------------------------------------------------------
# 监听地址
HOST=127.0.0.1

# 监听端口
PORT=18480

# 是否启用热重载（仅开发使用）
RELOAD=false

# ----------------------------------------------------------------------------
# Feature Flags — 可选
# ----------------------------------------------------------------------------
# 后端 v2 功能开关
BACKEND_V2_ENABLED=true

# v2 流量百分比（0-100）
BACKEND_V2_TRAFFIC_PERCENT=100
